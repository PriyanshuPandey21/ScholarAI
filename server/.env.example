# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5001
MONGODB_URI=your_mongodb_connection_string
SESSION_SECRET=your_session_secret
CLIENT_URL=http://localhost:5173

# ─── Gemini API Keys (Multi-Key Rotation) ────────────────────────────────────
# Add as many keys as you have. The system rotates automatically on quota errors.
# At least GEMINI_KEY_1 is required. Add more for higher throughput.
GEMINI_KEY_1=your_gemini_api_key_1_here
GEMINI_KEY_2=your_gemini_api_key_2_here
GEMINI_KEY_3=your_gemini_api_key_3_here
GEMINI_KEY_4=your_gemini_api_key_4_here
GEMINI_KEY_5=your_gemini_api_key_5_here
# GEMINI_KEY_6=your_gemini_api_key_6_here
# GEMINI_KEY_7=your_gemini_api_key_7_here
# GEMINI_KEY_8=your_gemini_api_key_8_here
# GEMINI_KEY_9=your_gemini_api_key_9_here
# GEMINI_KEY_10=your_gemini_api_key_10_here

# ─── OAuth Credentials ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── Optional API Keys ───────────────────────────────────────────────────────
SAPLING_API_KEY=your_sapling_api_key
GOOGLE_CSE_API_KEY=your_google_cse_api_key
GOOGLE_CSE_ID=your_google_cse_id
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key
